# ==============================================================================
# .env 示例文件（请勿直接使用！）
# 说明：
# 1. 复制此文件为 .env 
# 2. .env 已在 .gitignore 中，不会提交到Git（保护敏感信息）
# ==============================================================================

# 核心域名
DOMAIN = your_domain_here

# 用于加密 Session
SECRET_KEY = your_secret_key

# 服务端视频缓存限制（单位：MB，默认 15，仅缓存不超过该大小的小文件）
MAX_CACHE_SIZE_MB = 15
